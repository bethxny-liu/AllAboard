<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{YYYY-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Default everything to INFO (TRACE root is what causes the Ktor client plugin spam) -->
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>

    <!-- Keep noisy internals quieter -->
    <logger name="org.eclipse.jetty" level="INFO"/>
    <logger name="io.netty" level="INFO"/>

    <!-- Suppress Ktor client TRACE/DEBUG output -->
    <logger name="io.ktor.client.plugins" level="WARN"/>
    <logger name="io.ktor.client" level="WARN"/>
</configuration>